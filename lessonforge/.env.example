# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=lessonforge.com,www.lessonforge.com,localhost,127.0.0.1
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lessonforge
# For development: DATABASE_URL=sqlite:///db.sqlite3

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@lessonforge.com
SERVER_EMAIL=admin@lessonforge.com

# For Mailgun
ANYMAIL_SERVICE=mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_SENDER_DOMAIN=mg.lessonforge.com

# CORS
CORS_ALLOWED_ORIGINS=https://lessonforge.com,https://www.lessonforge.com

# Sentry (Optional - for error tracking)
SENTRY_DSN=your-sentry-dsn-here

# Application Settings
LESSONFORGE_FREE_PLAN_LIMIT=5
LESSONFORGE_TEACHER_PLAN_LIMIT=50
LESSONFORGE_TEACHER_PLAN_PRICE=5000
LESSONFORGE_SCHOOL_PLAN_PRICE=20000
